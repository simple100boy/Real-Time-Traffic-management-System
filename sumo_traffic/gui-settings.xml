<?xml version="1.0" encoding="UTF-8"?>
<viewsettings>

    <!-- Camera / View -->
    <viewport zoom="150" x="200" y="0"/>
    <delay value="20"/>

    <!-- Road appearance -->
    <scheme name="real world">
        <background backgroundColor="50,50,50"
                     showGrid="0"
                     gridXSize="100"
                     gridYSize="100"/>

        <edges laneEdgeMode="0"
               laneShowBorders="1"
               showLinkDecals="1"
               showRails="1"
               hideConnectors="0"
               widthExaggeration="1.5"
               wordWrapLength="10"
               edgeName_show="0"
               internalEdgeName_show="0"
               cwaEdgeName_show="0"
               streetName_show="0"
               edgeValue_show="0"
               edgeValueHideCheck="0"
               edgeValueHideCheck2="0"
               edgeValueRainBow="0"/>

        <!-- Vehicle appearance — bigger, smoother, colored -->
        <vehicles vehicleMode="0"
                  vehicleQuality="3"
                  minVehicleSize="4"
                  vehicleExaggeration="2"
                  showBlinker="1"
                  drawMinGap="0"
                  showBTRange="0"
                  showRouteIndex="0"
                  vehicle_length_exaggeration="1"
                  vehicleName_show="0"
                  vehicleValue_show="0"
                  vehicleScaleValue_show="0"
                  vehicleColorBarExaggeration="1"
                  vehicleText_show="0"/>

        <!-- Junction appearance -->
        <junctions junctionMode="0"
                   drawLinkTLIndex="0"
                   drawLinkJunctionIndex="0"
                   junctionName_show="0"
                   internalJunctionName_show="0"
                   tlsPhaseIndex_show="0"
                   tlsPhaseName_show="0"
                   junctionValue_show="0"/>

        <persons personMode="0"
                 personQuality="3"
                 minPersonSize="2"
                 personExaggeration="2"
                 personName_show="0"
                 personValue_show="0"/>

        <pois poiMode="0"
              poiExaggeration="1"
              poiMinSize="2"
              poiName_show="0"
              poiType_show="0"
              poiText_show="0"/>

        <polys polyMode="0"
               polyExaggeration="1"
               polyMinSize="2"
               polyName_show="0"
               polyType_show="0"
               polyText_show="0"/>

        <legend showSizeLegend="0"
                showColorLegend="0"
                showVehicleColorLegend="0"/>
    </scheme>

</viewsettings>
<?xml version="1.0" encoding="UTF-8"?>
<routes>

    <!-- Vehicle Types -->
<!-- Replace your existing vType lines with these -->

<vType id="car"
       accel="1.8"
       decel="3.0"
       sigma="0.3"
       length="4.5"
       minGap="2.5"
       maxSpeed="50"
       speedFactor="1.0"
       speedDev="0.1"
       carFollowModel="IDM"
       color="0.2,0.4,1.0"/>

<vType id="bus"
       accel="1.0"
       decel="2.5"
       sigma="0.1"
       length="12"
       minGap="3.0"
       maxSpeed="30"
       speedFactor="1.0"
       speedDev="0.05"
       carFollowModel="IDM"
       color="1,0.5,0"/>

<vType id="truck"
       accel="0.8"
       decel="2.0"
       sigma="0.1"
       length="10"
       minGap="3.5"
       maxSpeed="25"
       speedFactor="1.0"
       speedDev="0.05"
       carFollowModel="IDM"
       color="0.8,0.2,0.2"/>
    <!-- Routes -->
    <route id="route_AB_BC" edges="AB BC"/>
    <route id="route_CB_BA" edges="CB BA"/>
    <route id="route_DB_BC" edges="DB BC"/>
    <route id="route_AB_BD" edges="AB BD"/>
    <route id="route_EB_BC" edges="EB BC"/>
    <route id="route_BC_BD" edges="BC CB BD"/>

    <!-- ── MAIN FLOWS — run for full 5 minutes (300 seconds) ── -->

    <!-- Heavy main road traffic A → C -->
    <flow id="main_cars_1"
          type="car"
          route="route_AB_BC"
          begin="0" end="300"
          vehsPerHour="1200"
          departSpeed="max"
          departLane="best"/>

    <!-- Return traffic C → A -->
    <flow id="return_cars_1"
          type="car"
          route="route_CB_BA"
          begin="0" end="300"
          vehsPerHour="800"
          departSpeed="max"
          departLane="best"/>

    <!-- North to east traffic D → C -->
    <flow id="north_cars"
          type="car"
          route="route_DB_BC"
          begin="0" end="300"
          vehsPerHour="600"
          departSpeed="max"
          departLane="best"/>

    <!-- South to east traffic E → C -->
    <flow id="south_cars"
          type="car"
          route="route_EB_BC"
          begin="0" end="300"
          vehsPerHour="500"
          departSpeed="max"
          departLane="best"/>

    <!-- A → D cross traffic -->
    <flow id="cross_traffic"
          type="car"
          route="route_AB_BD"
          begin="0" end="300"
          vehsPerHour="400"
          departSpeed="max"
          departLane="best"/>

    <!-- Buses — all directions -->
    <flow id="bus_flow_1"
          type="bus"
          route="route_AB_BC"
          begin="0" end="300"
          vehsPerHour="60"
          departSpeed="max"
          departLane="best"/>

    <flow id="bus_flow_2"
          type="bus"
          route="route_DB_BC"
          begin="0" end="300"
          vehsPerHour="40"
          departSpeed="max"
          departLane="best"/>

    <!-- Trucks -->
    <flow id="truck_flow_1"
          type="truck"
          route="route_AB_BC"
          begin="0" end="300"
          vehsPerHour="80"
          departSpeed="max"
          departLane="best"/>

    <flow id="truck_flow_2"
          type="truck"
          route="route_CB_BA"
          begin="0" end="300"
          vehsPerHour="50"
          departSpeed="max"
          departLane="best"/>

    <!-- ── RUSH HOUR SPIKE at 2 minutes (120s) ── -->
    <flow id="rush_spike_1"
          type="car"
          route="route_AB_BC"
          begin="120" end="200"
          vehsPerHour="2000"
          departSpeed="max"
          departLane="best"/>

    <flow id="rush_spike_2"
          type="car"
          route="route_DB_BC"
          begin="120" end="200"
          vehsPerHour="1500"
          departSpeed="max"
          departLane="best"/>

</routes>